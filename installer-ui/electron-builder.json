{
  "appId": "com.loklm.installer",
  "productName": "LokLM Installer",
  "directories": {
    "app": "installer-ui",
    "output": "release/installer",
    "buildResources": "resources"
  },
  "files": ["**/*"],
  "asar": true,
  "npmRebuild": false,
  "compression": "store",
  "electronLanguages": ["en-US", "de"],
  "extraResources": [
    {
      "from": "resources/icon.ico",
      "to": "icon.ico"
    },
    {
      "from": "LICENSE",
      "to": "LICENSE"
    }
  ],
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ],
    "icon": "resources/icon.ico"
  }
}
