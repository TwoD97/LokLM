---
import Base from '~/layouts/Base.astro'
import { getLangFromUrl } from '~/i18n/utils'
import { t, type UIKey } from '~/i18n/ui'
import { pillars, personas, pillarUrl, personaUrl, type PillarKey } from '~/data/cluster'

interface Props {
  pillar: PillarKey
}
const { pillar } = Astro.props
const lang = getLangFromUrl(Astro.url)

const titleKey = `pillar.${pillar}.title` as UIKey
const leadKey = `pillar.${pillar}.lead` as UIKey

// rule 2: full mesh — link to the other two pillars + all four personas
const otherPillars = pillars
  .filter((p) => p.key !== pillar)
  .map((p) => ({ href: pillarUrl(p.key, lang), label: t(lang, `pillar.${p.key}.title` as UIKey) }))
const personaLinks = personas.map((p) => ({
  href: personaUrl(p.key, lang),
  label: t(lang, `persona.${p.key}.title` as UIKey),
}))

const alternates = { de: pillarUrl(pillar, 'de'), en: pillarUrl(pillar, 'en') }
---

<Base title={`${t(lang, titleKey)} — LokLM`} description={t(lang, leadKey)} alternates={alternates}>
  <main class="cluster">
    <div class="cluster__inner">
      <span class="section-eyebrow">{t(lang, 'cluster.relatedPillars')}</span>
      <h1 class="cluster__title gradient-text">{t(lang, titleKey)}</h1>
      <p class="cluster__lead">{t(lang, leadKey)}</p>

      <nav class="cluster__links" aria-label={t(lang, 'cluster.relatedPersonas')}>
        <span class="cluster__links-label">{t(lang, 'cluster.relatedPersonas')}</span>
        <ul>
          {personaLinks.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="cluster__links" aria-label={t(lang, 'cluster.relatedPillars')}>
        <span class="cluster__links-label">{t(lang, 'cluster.relatedPillars')}</span>
        <ul>
          {otherPillars.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </main>
</Base>

<style>
  .cluster {
    padding: 6rem 0 8rem;
  }
  .cluster__inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .cluster__title {
    margin-top: 0.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .cluster__lead {
    margin-top: 1rem;
    color: var(--color-fg-2);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .cluster__links {
    margin-top: 2.5rem;
  }
  .cluster__links-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
  }
  .cluster__links ul {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cluster__links a {
    color: var(--color-fg-0);
    text-decoration: underline;
  }
</style>
