---
import Base from '~/layouts/Base.astro'
import { getLangFromUrl } from '~/i18n/utils'
import { t, type UIKey } from '~/i18n/ui'
import { getPersona, personaUrl, pillarUrl, type PersonaKey } from '~/data/cluster'
import { buildWebPageSchema, buildBreadcrumbSchema, buildFaqSchema } from '~/lib/schema'

interface Props {
  persona: PersonaKey
}
const { persona } = Astro.props
const lang = getLangFromUrl(Astro.url)
const p = getPersona(persona)

const titleKey = `persona.${persona}.title` as UIKey
const leadKey = `persona.${persona}.lead` as UIKey

// rule 3: link up to this persona's two pillars + download CTA
const relatedPillars = p.pillars.map((k) => ({
  href: pillarUrl(k, lang),
  label: t(lang, `pillar.${k}.title` as UIKey),
}))

// hreflang translation pair for this exact page
const alternates = { de: personaUrl(persona, 'de'), en: personaUrl(persona, 'en') }
const downloadHref = lang === 'de' ? '/#download' : '/en/#download'

const siteUrl = Astro.site!.toString().replace(/\/$/, '')
const pageUrl = `${siteUrl}${personaUrl(persona, lang)}`
const homeUrl = lang === 'de' ? siteUrl : `${siteUrl}/en`
const faq = [1, 2, 3].map((i) => ({
  question: t(lang, `persona.${persona}.faq.q${i}` as UIKey),
  answer: t(lang, `persona.${persona}.faq.a${i}` as UIKey),
}))
const schemas = [
  buildWebPageSchema({ url: pageUrl, name: t(lang, titleKey), description: t(lang, leadKey), lang }),
  buildBreadcrumbSchema([
    { name: 'LokLM', url: homeUrl },
    { name: t(lang, titleKey), url: pageUrl },
  ]),
  buildFaqSchema(faq),
]
---

<Base
  title={`${t(lang, titleKey)} — LokLM`}
  description={t(lang, leadKey)}
  alternates={alternates}
  schemas={schemas}
>
  <main class="cluster">
    <div class="cluster__inner">
      <span class="section-eyebrow">{t(lang, 'cluster.relatedPersonas')}</span>
      <h1 class="cluster__title gradient-text">{t(lang, titleKey)}</h1>
      <p class="cluster__lead">{t(lang, leadKey)}</p>

      <nav class="cluster__links" aria-label={t(lang, 'cluster.relatedPillars')}>
        <span class="cluster__links-label">{t(lang, 'cluster.relatedPillars')}</span>
        <ul>
          {relatedPillars.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <section class="cluster__faq">
        {
          faq.map((f) => (
            <details>
              <summary>{f.question}</summary>
              <p>{f.answer}</p>
            </details>
          ))
        }
      </section>

      <a class="cluster__cta" href={downloadHref}>{t(lang, 'nav.download')}</a>
    </div>
  </main>
</Base>

<style>
  .cluster {
    padding: 6rem 0 8rem;
  }
  .cluster__inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .cluster__title {
    margin-top: 0.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .cluster__lead {
    margin-top: 1rem;
    color: var(--color-fg-2);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .cluster__links {
    margin-top: 2.5rem;
  }
  .cluster__links-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
  }
  .cluster__links ul {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cluster__links a {
    color: var(--color-fg-0);
    text-decoration: underline;
  }
  .cluster__cta {
    display: inline-block;
    margin-top: 2.5rem;
    color: var(--color-accent-hover);
    font-family: var(--font-mono);
  }
  .cluster__faq {
    margin-top: 2.5rem;
    display: grid;
    gap: 0.5rem;
  }
  .cluster__faq details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
  }
  .cluster__faq summary {
    cursor: pointer;
    color: var(--color-fg-0);
    font-weight: 500;
  }
  .cluster__faq p {
    margin-top: 0.5rem;
    color: var(--color-fg-2);
    line-height: 1.6;
  }
</style>
