---
import { getLangFromUrl } from '~/i18n/utils'
import { t, type UIKey } from '~/i18n/ui'
import {
  currentRelease,
  downloadUrl,
  formatSize,
  type Platform,
  type ReleaseAsset,
} from '~/data/releases'

const lang = getLangFromUrl(Astro.url)

interface PlatformMeta {
  platform: Platform
  buttonKey: UIKey
  iconPaths: string
}

const platformMeta: Record<Platform, PlatformMeta> = {
  windows: {
    platform: 'windows',
    buttonKey: 'download.button.windows',
    iconPaths:
      'M0 3.449L9.75 2.1v9.451H0V3.449zM10.949 1.929L24 0v11.4H10.949V1.929zM0 12.6h9.75v9.451L0 20.699V12.6zM10.949 12.6H24V24l-13.051-1.929V12.6z',
  },
  macos: {
    platform: 'macos',
    buttonKey: 'download.button.macos',
    iconPaths:
      'M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.493-.12-1.09.42-2.24 1.1-2.99.788-.85 2.02-1.51 3.064-1.583zM3.5 8.86C3.5 6.4 5.41 4.96 7.45 4.96c1.05 0 2.1.6 2.92.6.78 0 2.04-.71 3.45-.59 0 0 2.07.15 3.4 1.58-1.04.6-3.32 2.05-3.32 5.06 0 3.46 3.04 4.66 3.04 4.66s-2.31 6.6-5.4 6.6c-1.06 0-1.92-.69-3.03-.69-1.13 0-2.19.7-3.04.7C2.07 22.88 0 16.2 0 11.45 0 8.84 1.55 8.86 3.5 8.86z',
  },
  linux: {
    platform: 'linux',
    buttonKey: 'download.button.linux',
    iconPaths:
      'M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489.123.797.508 1.566 1.176 2.235.668.668 1.43 1.054 2.218 1.184a3.42 3.42 0 0 0 2.402-.461c1.116-.69 2.046-1.778 2.713-2.93.66-1.137 1.05-2.36 1.05-3.58 0-1.221.391-2.444 1.05-3.58.667-1.153 1.598-2.241 2.714-2.93a3.42 3.42 0 0 0 2.402-.461c.788-.13 1.55-.516 2.218-1.184.668-.669 1.053-1.438 1.176-2.235.123-.805-.01-1.657-.287-2.489-.59-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A6.392 6.392 0 0 0 12.504 0z',
  },
}

const assets: ReleaseAsset[] = currentRelease.assets
const windowsAsset = assets.find((a) => a.platform === 'windows')
const primaryAvailable = windowsAsset && windowsAsset.available ? windowsAsset : undefined
---

<section id="download" class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-6">
    <div class="text-center">
      <span class="section-eyebrow">{t(lang, 'nav.download')}</span>
      <h2 class="section-title gradient-text">{t(lang, 'download.title')}</h2>
      <p class="mt-4 text-[color:var(--color-fg-2)] text-base sm:text-lg">
        {t(lang, 'download.subtitle')}
      </p>
    </div>

    <div
      class="mt-12 glass rounded-[14px] p-8 sm:p-10 relative overflow-hidden"
      data-download-card
    >
      <div
        class="absolute inset-0 pointer-events-none opacity-40"
        style="background: radial-gradient(circle at 80% 0%, rgba(59,130,246,0.18), transparent 50%);"
      >
      </div>

      <div class="relative grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
        <div>
          <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-1">
            {t(lang, 'download.version')}
          </p>
          <p class="text-xl font-semibold mono">v{currentRelease.version}</p>
        </div>
        <div>
          <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-1">
            {t(lang, 'download.released')}
          </p>
          <p class="text-xl font-semibold mono">{currentRelease.releasedAt}</p>
        </div>
        <div>
          <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-1">
            {t(lang, 'download.size')}
          </p>
          <p class="text-xl font-semibold mono">
            {primaryAvailable ? formatSize(primaryAvailable.sizeBytes) : '—'}
          </p>
        </div>
      </div>

      <div class="relative grid grid-cols-1 sm:grid-cols-3 gap-3" data-platform-grid>
        {
          assets.map((asset) => {
            const meta = platformMeta[asset.platform]
            const isAvailable = asset.available
            return (
              <div
                class:list={[
                  'relative rounded-[10px] p-4 transition-all',
                  isAvailable
                    ? 'bg-white/[0.03] border border-[color:var(--color-border)] hover:border-[color:var(--color-accent)]/40'
                    : 'bg-white/[0.015] border border-dashed border-white/[0.08] opacity-60',
                ]}
                data-platform={asset.platform}
              >
                <div class="flex items-start gap-3 mb-3">
                  <div
                    class:list={[
                      'w-9 h-9 rounded-md grid place-items-center flex-shrink-0',
                      isAvailable
                        ? 'bg-[rgba(59,130,246,0.1)] border border-[rgba(59,130,246,0.3)] text-[color:var(--color-accent-hover)]'
                        : 'bg-white/[0.03] border border-white/[0.06] text-[color:var(--color-fg-3)]',
                    ]}
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d={meta.iconPaths} />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="mono uppercase tracking-wider text-[0.65rem] text-[color:var(--color-fg-3)]">
                      {asset.platform}
                    </p>
                    {isAvailable ? (
                      <p class="mono text-xs text-[color:var(--color-fg-1)] truncate">
                        {formatSize(asset.sizeBytes)}
                      </p>
                    ) : (
                      <p class="text-xs text-[color:var(--color-fg-2)]">
                        {t(lang, 'download.comingSoon')}
                      </p>
                    )}
                  </div>
                </div>

                {isAvailable ? (
                  <a
                    href={downloadUrl(asset)}
                    class="btn-primary w-full text-sm py-2.5"
                    data-platform-link={asset.platform}
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M12 3v12" />
                      <path d="m6 9 6 6 6-6" />
                      <path d="M5 21h14" />
                    </svg>
                    {t(lang, meta.buttonKey)}
                  </a>
                ) : (
                  <button
                    type="button"
                    disabled
                    class="w-full text-sm py-2.5 rounded-[10px] border border-white/[0.06] bg-white/[0.02] text-[color:var(--color-fg-3)] mono uppercase tracking-wider text-xs cursor-not-allowed"
                  >
                    {t(lang, 'download.comingSoon')}
                  </button>
                )}

                <span
                  class="absolute -top-2 left-4 hidden mono uppercase tracking-wider text-[0.6rem] px-2 py-0.5 rounded-full bg-[color:var(--color-accent)] text-white"
                  data-detected-badge
                >
                  {t(lang, 'download.detected')}
                </span>
              </div>
            )
          })
        }
      </div>

      <p class="relative mt-6 text-sm text-[color:var(--color-fg-2)] leading-relaxed flex items-start gap-2">
        <svg
          class="mt-0.5 flex-shrink-0"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4"></path>
          <path d="M12 8h.01"></path>
        </svg>
        <span>{t(lang, 'download.notice')}</span>
      </p>

      {
        primaryAvailable && primaryAvailable.sha256 && (
          <div class="relative mt-6 pt-6 border-t border-white/5">
            <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-2">
              {t(lang, 'download.checksum')} — {primaryAvailable.file}
            </p>
            <code class="mono text-xs text-[color:var(--color-fg-1)] break-all block bg-[rgba(255,255,255,0.03)] border border-[color:var(--color-border)] rounded-md p-3">
              {primaryAvailable.sha256}
            </code>
          </div>
        )
      }
    </div>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="glass rounded-[10px] p-4">
        <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-2">
          {t(lang, 'download.requirements.title')}
        </p>
        <p class="text-[color:var(--color-fg-1)]">{t(lang, 'download.requirements.windows')}</p>
      </div>
      <div class="glass rounded-[10px] p-4">
        <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-2">
          RAM
        </p>
        <p class="text-[color:var(--color-fg-1)]">{t(lang, 'download.requirements.ram')}</p>
      </div>
      <div class="glass rounded-[10px] p-4">
        <p class="mono text-[0.7rem] uppercase tracking-wider text-[color:var(--color-fg-3)] mb-2">
          Disk
        </p>
        <p class="text-[color:var(--color-fg-1)]">{t(lang, 'download.requirements.disk')}</p>
      </div>
    </div>
  </div>
</section>

<script>
  // os detection läuft client-side , markiert die passende card , wenn js aus
  // ist bleibt alles normal sichtbar.
  function detectOS(): 'windows' | 'macos' | 'linux' | null {
    if (typeof navigator === 'undefined') return null

    // userAgentData wenn da , sonst userAgent string parsen.
    // navigator.platform ist deprecated.
    const uaData = (navigator as Navigator & { userAgentData?: { platform: string } })
      .userAgentData
    const platformHint = (uaData?.platform ?? navigator.userAgent).toLowerCase()

    if (platformHint.includes('win')) return 'windows'
    if (platformHint.includes('mac') || platformHint.includes('darwin')) return 'macos'
    if (platformHint.includes('linux') || platformHint.includes('x11')) return 'linux'
    return null
  }

  const os = detectOS()
  if (os) {
    const card = document.querySelector(`[data-platform="${os}"]`)
    if (card) {
      card.classList.add('ring-2', 'ring-[color:var(--color-accent)]/40', 'shadow-[0_0_0_4px_rgba(59,130,246,0.08)]')
      const badge = card.querySelector('[data-detected-badge]') as HTMLElement | null
      if (badge) badge.style.display = 'inline-block'
    }
  }
</script>
