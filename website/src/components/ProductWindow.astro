---
// product-window , gemeinsames chrome für screenshots im hero , how-it-works und feature-deepdives.
// gerundete ecken , drop-shadow , optionaler glow + 3d-tilt. keine titlebar — das app-screenshot bringt seine eigene mit.
interface Props {
  glow?: boolean
  tilt?: boolean
  class?: string
}

const { glow = false, tilt = false, class: extraClass = '' } = Astro.props
---

<div
  class:list={[
    'product-window',
    glow && 'product-window--glow',
    tilt && 'product-window--tilt',
    extraClass,
  ]}
>
  <div class="product-window__body">
    <slot />
  </div>
</div>

<style>
  .product-window {
    position: relative;
    border-radius: 12px;
    background: #161b22;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 30px 80px rgba(0, 0, 0, 0.55);
    overflow: hidden;
  }

  .product-window--glow::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.25), transparent 60%);
    z-index: -1;
    filter: blur(20px);
  }

  .product-window--tilt {
    transform: perspective(1200px) rotateY(-8deg);
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-window--tilt {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .product-window--tilt {
      transform: none;
    }
  }

  .product-window__body {
    position: relative;
  }

  .product-window__body :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
