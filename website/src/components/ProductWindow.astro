---
// product-window , gemeinsames chrome für screenshots im hero , how-it-works und feature-deepdives.
// drei-punkt-titlebar , gerundete ecken , drop-shadow , optionaler glow + 3d-tilt.
interface Props {
  label?: string
  glow?: boolean
  tilt?: boolean
  class?: string
}

const { label, glow = false, tilt = false, class: extraClass = '' } = Astro.props
---

<div
  class:list={[
    'product-window',
    glow && 'product-window--glow',
    tilt && 'product-window--tilt',
    extraClass,
  ]}
>
  <div class="product-window__bar">
    <span class="product-window__dot product-window__dot--red"></span>
    <span class="product-window__dot product-window__dot--yellow"></span>
    <span class="product-window__dot product-window__dot--green"></span>
    {label && <span class="product-window__label">{label}</span>}
  </div>
  <div class="product-window__body">
    <slot />
  </div>
</div>

<style>
  .product-window {
    position: relative;
    border-radius: 12px;
    background: #161b22;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 30px 80px rgba(0, 0, 0, 0.55);
    overflow: hidden;
  }

  .product-window--glow::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.25), transparent 60%);
    z-index: -1;
    filter: blur(20px);
  }

  .product-window--tilt {
    transform: perspective(1200px) rotateY(-8deg);
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-window--tilt {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .product-window--tilt {
      transform: none;
    }
  }

  .product-window__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    background: rgba(255, 255, 255, 0.015);
  }

  .product-window__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .product-window__dot--red { background: #f85149; }
  .product-window__dot--yellow { background: #d29922; }
  .product-window__dot--green { background: #3fb950; }

  .product-window__label {
    margin-left: 12px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-fg-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-window__body {
    position: relative;
  }

  .product-window__body :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
