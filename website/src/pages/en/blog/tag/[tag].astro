---
import { getCollection } from 'astro:content'
import BlogIndex from '~/layouts/BlogIndex.astro'
import { postsForLang, tagsForLang } from '~/data/blog'

export async function getStaticPaths() {
  const all = await getCollection('blog')
  return tagsForLang(all, 'en').map((tag) => ({
    params: { tag },
    props: { posts: postsForLang(all, 'en').filter((p) => p.data.tags.includes(tag)) },
  }))
}

const { posts } = Astro.props
---

<BlogIndex lang="en" posts={posts} />
