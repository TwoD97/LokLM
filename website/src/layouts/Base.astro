---
import '@fontsource-variable/inter'
import '~/styles/global.css'
import BackgroundFx from '~/components/BackgroundFx.astro'
import Nav from '~/components/Nav.astro'
import Footer from '~/components/Footer.astro'
import { getLangFromUrl } from '~/i18n/utils'
import { currentRelease, downloadUrl } from '~/data/releases'
import { buildOrganizationSchema, buildSoftwareSchema } from '~/lib/schema'
import { resolveAlternates, type AlternatePaths } from '~/lib/alternates'
import interLatinFont from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url'

interface Props {
  title: string
  description: string
  /** translation pair for hreflang; omit for the homepage pair */
  alternates?: AlternatePaths
}

const { title, description, alternates } = Astro.props
const lang = getLangFromUrl(Astro.url)

const siteUrl = Astro.site!.toString().replace(/\/$/, '')
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
const canonical = `${siteUrl}${pathname === '/' ? '' : pathname}`

const alt = resolveAlternates(siteUrl, alternates)
const deUrl = alt.de
const enUrl = alt.en
const xDefaultUrl = alt.xDefault

const ogLocale = lang === 'de' ? 'de_DE' : 'en_US'
const ogLocaleAlternate = lang === 'de' ? 'en_US' : 'de_DE'
const siteName = 'LokLM'

const windowsAsset = currentRelease.assets.find((a) => a.platform === 'windows' && a.available)
const winDownloadUrl = windowsAsset ? downloadUrl(windowsAsset) : undefined

const organizationSchema = buildOrganizationSchema({ siteUrl, siteName })

const softwareSchema = buildSoftwareSchema({
  siteUrl,
  siteName,
  description,
  softwareVersion: currentRelease.version,
  winDownloadUrl,
})
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Denys Tudosa, Dominik Furlan" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de" href={deUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/brand/app-paper.svg" />
    <link rel="mask-icon" href="/brand/mark-mono.svg" color="#0B1B2B" />
    <link rel="preload" href={interLatinFont} as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image" content={`${siteUrl}/brand/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/brand/og.png`} />
    <meta name="twitter:image:alt" content={title} />

    <meta name="theme-color" content="#0B1B2B" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(softwareSchema)}
    />
  </head>
  <body class="min-h-screen relative">
    <BackgroundFx />
    <div class="relative z-10">
      <Nav />
      <slot />
      <Footer />
    </div>
  </body>
</html>
