# Beispiel-config fuer eval-tests. Kopieren als .env (gitignored) und ausfuellen.
# Wird von tests/evals/synth/generate-dataset.ts und
# tests/evals/scale/build-library.ts ueber dotenv/config geladen.

# Remote-Ollama (zB RunPod-proxy). Wenn leer , faellt der generator auf
# http://127.0.0.1:11434 zurueck.
OLLAMA_BASE_URL=
# Optionaler bearer-token. Nur setzen wenn der proxy einen verlangt.
# Fuer den oeffentlichen RunPod-proxy NICHT noetig.
OLLAMA_BEARER_TOKEN=

# Fuer den anthropic-generator (synth/AnthropicGenerator , scale/AnthropicDocGenerator).
ANTHROPIC_API_KEY=

# RunPod control-plane (fuer pnpm pod:start , pnpm pod:stop , pnpm pod:status).
# API-key in https://www.runpod.io/console/user/settings erstellen.
# Pod-ID steht in der URL der Pod-Detail-Seite.
RUNPOD_API_KEY=
RUNPOD_POD_ID=

# Modelle , die pnpm pod:start nach dem boot pullt + ins VRAM laedt
# (keep_alive: -1). Leer lassen = ueberspringen.
OLLAMA_LLM_MODEL=
OLLAMA_EMBEDDER_MODEL=
OLLAMA_RERANKER_MODEL=

# WICHTIG: Damit die gepullten Modelle NICHT bei jedem Pod-Stop verschwinden ,
# muss im RunPod-Pod (Template oder "Edit Pod" -> Environment Variables) die
# var OLLAMA_MODELS auf einen Pfad im Network-Volume zeigen , zB:
#   OLLAMA_MODELS=/workspace/ollama
# Sonst landen die Modelle auf der ephemeren Container-Disk und der erste
# pod:start nach einem Stop pullt jedes Modell erneut. Diese var wird nicht
# vom Client gesetzt , sie gehoert in die Pod-Konfiguration selbst.
