{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LokLM",
  "version": "0.3.0",
  "identifier": "com.loklm.bootstrap",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": null,
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LokLM",
        "url": "index.html",
        "width": 980,
        "height": 740,
        "minWidth": 980,
        "minHeight": 740,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "backgroundColor": "#07111f",
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Projektgruppe LokLM",
    "category": "Productivity",
    "shortDescription": "LokLM",
    "longDescription": "LokLM ( Lokaler KI-Wissensassistent ). Native Rust + WebView2 launcher that fetches the app from the LokLM CDN and places it into the user profile.",
    "copyright": "© Projektgruppe LokLM ( MIT )",
    "linux": {
      "deb": {
        "section": "utils",
        "priority": "optional"
      }
    }
  }
}
