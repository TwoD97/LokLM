{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LokLM Installer",
  "version": "0.2.7",
  "identifier": "com.loklm.installer",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": null,
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LokLM Installer",
        "url": "index.html",
        "width": 980,
        "height": 740,
        "minWidth": 980,
        "minHeight": 740,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "backgroundColor": "#07111f",
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Projektgruppe LokLM",
    "category": "Productivity",
    "shortDescription": "LokLM Installer",
    "longDescription": "Installs LokLM ( Lokaler KI-Wissensassistent ) into the user profile and registers shortcuts , autostart , and uninstaller. Renders the wizard via WebView2 ; the install logic is native Rust ( robocopy + powershell + reg.exe ).",
    "copyright": "© Projektgruppe LokLM ( MIT )"
  }
}
