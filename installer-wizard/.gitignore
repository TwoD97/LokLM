# Rust build output (~hundreds of MB)
src-tauri/target/

# Tauri-generated config files that shouldn't be committed
src-tauri/.cargo/
src-tauri/gen/

# Mobile-platform icons auto-generated by `cargo tauri icon` ; we don't
# target android/ios , and the Windows + macOS bits are all we need.
src-tauri/icons/android/
src-tauri/icons/ios/
