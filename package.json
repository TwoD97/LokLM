{
  "name": "loklm",
  "version": "0.1.0",
  "description": "LokLM — Lokaler KI-Wissensassistent mit Quellenverifikation",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "author": "Projektgruppe LokLM (Denys Tudosa, Dominik Furlan)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:unit": "vitest run --project node --project web",
    "test:integration": "vitest run --project integration",
    "test:tx": "vitest run --project tx",
    "pretest:e2e": "pnpm build",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config tests/e2e/playwright.config.ts --headed",
    "test:all": "pnpm test && pnpm test:e2e",
    "evals:generate": "tsx tests/evals/synth/generate-dataset.ts",
    "evals:run": "tsx tests/evals/run.ts",
    "evals:build-library": "tsx tests/evals/scale/build-library.ts",
    "evals:scale": "tsx tests/evals/scale/run-scale.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "doc": "typedoc",
    "doc:watch": "typedoc --watch",
    "prepare": "husky",
    "postinstall": "electron-rebuild -f -w argon2 || echo \"electron-rebuild skipped (no native deps yet to rebuild)\"",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "electron",
      "@electron/rebuild"
    ],
    "overrides": {
      "esbuild": "0.25.12"
    }
  }
}
